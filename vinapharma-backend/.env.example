# =============================================
# VINAPHARMA BACKEND - CẤU HÌNH MÔI TRƯỜNG
# =============================================
# Đổi tên file này thành .env và điền thông tin thật

# MongoDB Atlas Connection String
# Lấy từ: MongoDB Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vinapharma?retryWrites=true&w=majority

# JWT Secret Key (đặt chuỗi bất kỳ, càng dài càng bảo mật)
JWT_SECRET=vinapharma_super_secret_key_2024_doi_chuoi_nay

# JWT hết hạn sau bao lâu
JWT_EXPIRES_IN=7d

# Port server
PORT=5000

# Môi trường
NODE_ENV=development
